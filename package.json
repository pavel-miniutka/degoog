{
  "name": "degoog",
  "version": "0.11.0",
  "type": "module",
  "scripts": {
    "dev": "bun run --watch src/server/index.ts",
    "build": "bun run build.ts",
    "build:watch": "bun run build.ts --watch",
    "stop": "kill $(lsof -t -i:4444)",
    "start": "bun run src/server/index.ts",
    "start:dev": "DEGOOG_PORT=4445 bun run src/server/index.ts --debug",
    "develop": "yarn build:watch; yarn run stop; yarn run start:dev",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/ tests/",
    "lint:fix": "eslint src/ tests/ --fix",
    "test": "LOGGER= bun test $(find tests -name '*.test.ts' ! -path '*/stress/*' | sort | tr '\\n' ' ')",
    "test:rate-limit": "LOGGER=debug bun test tests/stress/"
  },
  "dependencies": {
    "cheerio": "1.2.0",
    "hono": "4.12.7",
    "sass": "1.85.0",
    "socks": "2.8.7"
  },
  "devDependencies": {
    "@types/bun": "1.2.0",
    "esbuild": "0.27.3",
    "eslint": "10.0.3",
    "typescript": "5.7.3",
    "typescript-eslint": "8.56.1"
  },
  "resolutions": {
    "brace-expansion": "5.0.5",
    "flatted": "3.4.2",
    "hono": "4.12.7",
    "picomatch": "4.0.4",
    "undici": "7.24.0"
  }
}
