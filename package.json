{
  "name": "degoog",
  "version": "0.6.1-beta.1",
  "type": "module",
  "scripts": {
    "dev": "bun run --watch src/server/index.ts",
    "build": "bun run build.ts",
    "build:watch": "bun run build.ts --watch",
    "stop": "kill $(lsof -t -i:4444)",
    "start": "bun run src/server/index.ts",
    "start:dev": "DEGOOG_PORT=4445 bun run src/server/index.ts --debug",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/ tests/",
    "lint:fix": "eslint src/ tests/ --fix",
    "test": "bun test"
  },
  "dependencies": {
    "cheerio": "^1.0.0",
    "hono": "^4.7.0",
    "sass": "^1.85.0",
    "undici": "^7.22.0"
  },
  "devDependencies": {
    "@types/bun": "^1.2.0",
    "esbuild": "^0.27.3",
    "eslint": "^10.0.3",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.56.1"
  }
}
